# Copy this to server/.env on the VPS and fill in real values

# SQLite (簡單但不支援併發寫入)
DATABASE_URL="file:/var/www/fusheng/data/prod.db"

# 如果改用 PostgreSQL（推薦生產環境）:
# DATABASE_URL="postgresql://fusheng:STRONG_PASSWORD@localhost:5432/fusheng"

# JWT Secrets - 必須至少 32 字元、完全隨機
# 產生方式: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_RUN_openssl_rand_base64_48"
JWT_REFRESH_SECRET="CHANGE_ME_RUN_openssl_rand_base64_48_AGAIN"

# 環境
PORT=3001
NODE_ENV=production

# CORS - 你的網域
CLIENT_URL="https://your-domain.com"
